// ============================================
// Prisma スキーマファイル（MySQL版）
// 【変更点】PostgreSQL(Supabase) → MySQL(phpMyAdmin/MAMP) へ切り替え
// ============================================

generator client {
  provider = "prisma-client-js"
}

// MySQLでは基本的にpoolingの直接接続(directUrl)を分ける必要が無いため、
// DATABASE_URL 1本だけを見るようにしている
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// ここから実際のテーブル定義（中身はPostgres版と同じ）
// ============================================

model Office {
  id     String  @id @default(cuid())
  name   String
  groups Group[]
  talents Talent[]
}

model Group {
  id       String   @id @default(cuid())
  name     String
  officeId String
  office   Office   @relation(fields: [officeId], references: [id])
  units    Unit[]
  talents  Talent[]
}

model Unit {
  id      String   @id @default(cuid())
  name    String
  groupId String
  group   Group    @relation(fields: [groupId], references: [id])
  talents Talent[]
}

model Talent {
  id       String    @id @default(cuid())
  name     String

  sortOrder Int      @default(0)

  officeId String
  office   Office    @relation(fields: [officeId], references: [id])

  groupId  String?
  group    Group?    @relation(fields: [groupId], references: [id])

  units    Unit[]

  channels Channel[]

  twitterUrl   String?
  instagramUrl String?
  tiktokUrl    String?
  hashtag      String?

  holodexTwitter     String?
  // 【変更点】説明文は長くなることがあるため、MySQLのデフォルト文字数制限
  // (String単体だとVARCHAR(191)になる)を避け、@db.Textで無制限にしておく
  holodexDescription String? @db.Text
  holodexInactive    Boolean   @default(false)
  holodexSyncedAt    DateTime?
}

model Channel {
  id         String   @id @default(cuid())
  talentId   String
  talent     Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  platform   String
  externalId String
  snapshots  SubscriberSnapshot[]
}

model SubscriberSnapshot {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  count     Int
  fetchedAt DateTime @default(now())
}
