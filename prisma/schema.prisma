// ============================================
// Prisma スキーマファイル（MySQL版）
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// ここから実際のテーブル定義
// ============================================

// 【事務所】ホロライブ、にじさんじ、あおぎり高校 など
model Office {
  id     String  @id @default(cuid())
  name   String

  // 【追加】公式チャンネル（グループ全体のまとめチャンネルなど）のURL
  // タレント本人ではないので、Talentとしては登録せず、こちらにリンクとして持たせる
  officialChannelUrl String?

  groups Group[]
  talents Talent[]
}

// 【グループ】ホロライブ内の「ホロライブ」「hololive EN」など
model Group {
  id       String   @id @default(cuid())
  name     String
  officeId String
  office   Office   @relation(fields: [officeId], references: [id])

  // 【追加】このグループの公式チャンネルURL
  officialChannelUrl String?

  units    Unit[]
  talents  Talent[]
}

// 【ユニット】グループの中の「ReGLOSS」「秘密結社holoX」のような小グループ
model Unit {
  id      String   @id @default(cuid())
  name    String
  groupId String
  group   Group    @relation(fields: [groupId], references: [id])

  // 【追加】このユニットの公式チャンネルURL
  officialChannelUrl String?

  talents Talent[]
}

// 【タレント】個々のVTuber本人
model Talent {
  id       String    @id @default(cuid())
  name     String

  sortOrder Int      @default(0)

  officeId String
  office   Office    @relation(fields: [officeId], references: [id])

  groupId  String?
  group    Group?    @relation(fields: [groupId], references: [id])

  units    Unit[]

  channels Channel[]

  twitterUrl   String?
  instagramUrl String?
  tiktokUrl    String?
  hashtag      String?

  holodexTwitter     String?
  holodexDescription String? @db.Text
  holodexInactive    Boolean   @default(false)
  holodexSyncedAt    DateTime?
}

// 【チャンネル】YouTubeチャンネルやX(Twitter)アカウントなど、外部サービスとの連携情報
model Channel {
  id         String   @id @default(cuid())
  talentId   String
  talent     Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  platform   String
  externalId String
  snapshots  SubscriberSnapshot[]
}

// 【登録者数スナップショット】「いつ・何人だったか」を記録するログテーブル
model SubscriberSnapshot {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  count     Int
  fetchedAt DateTime @default(now())
}
